# .mgitconfig - mgit configuration file
#
# Place this file in:
#   - Your repo root (repo-specific config)
#   - ~/.mgitconfig  (user-global config)
#
# Settings here EXTEND the built-in defaults; they do not replace them.
# (no_sign_emails entries are appended to the built-in bot list)

[signing]
# Additional emails that should skip GPG signing.
# One entry per line. Supports Python regex (full-string match).
# The built-in list already covers Claude, Copilot, Codex, Gemini,
# GitHub Actions, and any *[bot]@users.noreply.github.com pattern.
#
# no_sign_emails =
#     myci-bot@mycompany.com
#     deploy@mycompany.com

[refs]
# Commit message used when mgit push auto-commits updated submodule refs.
# commit_msg = "chore: update submodule refs"

[behavior]
# Set to true to enable verbose logging of every git command invoked.
# verbose = false

[gh]
# Classic personal access token for gh CLI (used by mgit detach and attach).
#
# Required scopes: repo, read:org, gist
# Create one at: https://github.com/settings/tokens
#
# This token is injected as GH_TOKEN into gh subprocesses only.
# It does not affect GITHUB_TOKEN in your environment, so a fine-grained
# token you use for your own API work is left completely untouched.
#
# Use this option if you already have GITHUB_TOKEN set in your environment
# for other purposes and do not want mgit to interfere with it.
#
# Alternatives (no config file needed):
#   gh auth login        — stores credentials in your system keychain /
#                          gh config file; picked up automatically
#   export GH_TOKEN=...  — overrides GITHUB_TOKEN for the current session
#
# Note: fine-grained personal access tokens cannot list org memberships
# or create repositories in organisations. Use a classic token here.
#
# token = ghp_yourclassictoken
