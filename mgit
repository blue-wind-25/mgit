#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
mgit - Multi-repo Git automation tool
Recursively manages git repositories with submodules,
handling commit ordering, signing enforcement, and ref updates.

Requires: Python 3.6+, git (stock)
Zero pip dependencies — stdlib only.
Tested on: CentOS 7, Ubuntu 18+, Windows 10/11 (Git for Windows + Python 3)
"""

from __future__ import print_function

import os
import re
import sys
import shutil
import tempfile
import fnmatch
import configparser
import subprocess
import unicodedata
from typing import List, Optional, Tuple


# ---------------------------------------------------------------------------
# Unicode normalization
# ---------------------------------------------------------------------------
def unorm(s: str) -> str:
    return unicodedata.normalize("NFC", s)

# ---------------------------------------------------------------------------
# Platform detection
# ---------------------------------------------------------------------------

IS_WINDOWS = sys.platform == "win32"

# ---------------------------------------------------------------------------
# Windows UTF-8 console output
# ---------------------------------------------------------------------------
# Force UTF-8 for stdout/stderr on Windows so non-ASCII filenames, repo
# names, and commit messages display correctly regardless of the system
# code page. reconfigure() is Python 3.7+; on 3.6 we silently skip it
# (Python 3.6 is EOL and has no clean stdlib-only UTF-8 console fix).
if IS_WINDOWS and sys.version_info >= (3, 7):
    sys.stdout.reconfigure(encoding="utf-8", errors="replace")  # type: ignore[attr-defined]
    sys.stderr.reconfigure(encoding="utf-8", errors="replace")  # type: ignore[attr-defined]

# ---------------------------------------------------------------------------
# Defaults (overridable via .mgitconfig)
# ---------------------------------------------------------------------------

VERSION = "1.6.0"

DEFAULT_REF_COMMIT_MSG = "chore: update submodule refs"

# Exact or regex patterns for emails that should NOT be GPG-signed.
# These are known AI agent / bot identities. Patterns are matched as
# case-insensitive full-string regex against git config user.email.
DEFAULT_NO_SIGN_EMAILS: List[str] = [
    # Claude (Anthropic)
    r"242468646\+claude@users\.noreply\.github\.com",
    r"claude\[bot\]@users\.noreply\.github\.com",
    r"noreply@anthropic\.com",
    # GitHub Copilot
    r"198982749\+copilot@users\.noreply\.github\.com",
    # GitHub Actions built-in
    r"41898282\+github-actions\[bot\]@users\.noreply\.github\.com",
    # OpenAI Codex variants
    r"codex@example\.com",                # bad default that ships with Codex CLI
    r"noreply@codex\.openai\.com",        # proposed official
    r"199175422\+chatgpt-codex-connector\[bot\]@users\.noreply\.github\.com",
    # Google Gemini
    r"218195315\+gemini-cli@users\.noreply\.github\.com",
    r"gemini-code-assist\[bot\]@.*",
    r"noreply@gemini\.google\.com",
    # Generic catch-all: any GitHub-hosted [bot] account
    r".*\[bot\]@users\.noreply\.github\.com",
]

# ---------------------------------------------------------------------------
# Config loader
# ---------------------------------------------------------------------------

class MgitConfig:
    """
    Loads .mgitconfig from (in order):
      1. repo root (cwd at startup)
      2. ~/.mgitconfig
    Settings extend built-in defaults; they do not replace them.
    """

    def __init__(self) -> None:
        self.ref_commit_msg: str = DEFAULT_REF_COMMIT_MSG
        self.no_sign_emails: List[str] = list(DEFAULT_NO_SIGN_EMAILS)
        self.verbose: bool = False
        self.gh_token: str = ""   # classic PAT for gh CLI (detach/attach)
        self._load()

    def _load(self) -> None:
        candidates = [
            os.path.join(os.getcwd(), ".mgitconfig"),
            os.path.expanduser("~/.mgitconfig"),
        ]
        parser = configparser.ConfigParser()
        for path in candidates:
            if os.path.isfile(path):
                parser.read(path)
                break  # first found wins

        if parser.has_option("refs", "commit_msg"):
            self.ref_commit_msg = parser.get("refs", "commit_msg").strip('"\'')

        if parser.has_option("signing", "no_sign_emails"):
            raw = parser.get("signing", "no_sign_emails")
            extras = [e.strip() for e in raw.splitlines() if e.strip()]
            self.no_sign_emails.extend(extras)  # append, never replace

        if parser.has_option("behavior", "verbose"):
            self.verbose = parser.getboolean("behavior", "verbose")

        if parser.has_option("gh", "token"):
            self.gh_token = parser.get("gh", "token").strip('"\'').strip()


CONFIG = MgitConfig()

# ---------------------------------------------------------------------------
# Logging helpers
# ---------------------------------------------------------------------------

def info(msg: str) -> None:
    print("[mgit] {}".format(msg), file=sys.stderr)

def verbose(msg: str) -> None:
    if CONFIG.verbose:
        print("[mgit] {}".format(msg), file=sys.stderr)

def warn(msg: str) -> None:
    print("[mgit] WARN: {}".format(msg), file=sys.stderr)

def error(msg: str) -> None:
    print("[mgit] ERROR: {}".format(msg), file=sys.stderr)

def die(msg: str, code: int = 1) -> None:
    error(msg)
    sys.exit(code)

def prompt(msg: str, default: str = "") -> str:
    """Prompt the user for input, with an optional default value."""
    display = "{} [{}]: ".format(msg, default) if default else "{}: ".format(msg)
    try:
        answer = input(display).strip()
    except (KeyboardInterrupt, EOFError):
        print()
        die("Aborted.")
    return answer if answer else default

def prompt_yes_no(msg: str, default: bool = True) -> bool:
    """Prompt for a yes/no answer. Returns True for yes, False for no."""
    hint = "Y/n" if default else "y/N"
    try:
        answer = input("{} [{}]: ".format(msg, hint)).strip().lower()
    except (KeyboardInterrupt, EOFError):
        print()
        die("Aborted.")
    if not answer:
        return default
    return answer in ("y", "yes")

def prompt_yes_no_sign(rel: str) -> str:
    """
    Prompt the user when commit.gpgsign is not set.
    Returns one of:
      'yes'       — proceed unsigned this time
      'no'        — skip this commit
      'configure' — set commit.gpgsign=true globally and sign from now on
    """
    print("[mgit] WARN: commit.gpgsign is not set for '{}' — "
          "this commit will be unsigned.".format(rel), file=sys.stderr)
    print("[mgit]", file=sys.stderr)
    print("[mgit]   y  continue without signing (this commit only)", file=sys.stderr)
    print("[mgit]   n  skip this commit", file=sys.stderr)
    print("[mgit]   c  enable signing globally (git config --global commit.gpgsign true)", file=sys.stderr)
    print("[mgit]      and sign this commit", file=sys.stderr)
    print("[mgit]", file=sys.stderr)
    while True:
        try:
            answer = input("[mgit] Choice [Y/n/c]: ").strip().lower()
        except (KeyboardInterrupt, EOFError):
            print()
            die("Aborted.")
        if answer in ("", "y", "yes"):
            return "yes"
        if answer in ("n", "no"):
            return "no"
        if answer in ("c", "configure"):
            return "configure"
        warn("Please enter y, n, or c.")

# ---------------------------------------------------------------------------
# Git subprocess helpers
# ---------------------------------------------------------------------------

def run_git(args: List[str], cwd: str = None, check: bool = True,
            capture: bool = False) -> subprocess.CompletedProcess:
    """Run git with given args in cwd. Streams output unless capture=True."""
    cmd = ["git"] + args

    # Copy system environment and force English logic
    env = os.environ.copy()
    env["LC_ALL"] = "C"
    env["LANG"] = "C"

    verbose("  $ {}  [in {}]".format(" ".join(cmd), cwd or os.getcwd()))
    if capture:
        result = subprocess.run(
            cmd, cwd=cwd, env=env,
            stdout=subprocess.PIPE, stderr=subprocess.PIPE, encoding="utf-8",
            universal_newlines=True
        )
    else:
        result = subprocess.run(cmd, cwd=cwd, env=env)
    if check and result.returncode != 0:
        if capture:
            sys.stderr.write(result.stderr)
        sys.exit(result.returncode)
    return result


def git_output(args: List[str], cwd: str = None) -> str:
    """Run git and return stdout; returns '' on error, never raises."""
    result = run_git(args, cwd=cwd, check=False, capture=True)
    return unorm(result.stdout.strip())


def git_ok(args: List[str], cwd: str = None) -> bool:
    """Return True if git command exits 0."""
    result = subprocess.run(
        ["git"] + args, cwd=cwd,
        stdout=subprocess.PIPE, stderr=subprocess.PIPE
    )
    return result.returncode == 0

# ---------------------------------------------------------------------------
# Repository discovery
# ---------------------------------------------------------------------------

def is_git_repo(path: str) -> bool:
    return git_ok(["rev-parse", "--git-dir"], cwd=path)


def get_toplevel(path: str) -> Optional[str]:
    """Return the git toplevel for path, or None if not in a repo."""
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        cwd=path,
        stdout=subprocess.PIPE, stderr=subprocess.PIPE, encoding="utf-8",
        universal_newlines=True
    )
    if result.returncode == 0:
        return result.stdout.strip()
    return None


def get_submodule_paths(repo_root: str) -> List[str]:
    """
    Return list of absolute paths for all direct submodules of repo_root,
    as declared in .gitmodules. Returns [] if none or unpopulated.
    """
    gitmodules = os.path.join(repo_root, ".gitmodules")
    if not os.path.isfile(gitmodules):
        return []

    result = subprocess.run(
        ["git", "config", "--file", ".gitmodules",
         "--get-regexp", r"submodule\..*\.path"],
        cwd=repo_root,
        stdout=subprocess.PIPE, stderr=subprocess.PIPE, encoding="utf-8",
        universal_newlines=True
    )
    if result.returncode != 0:
        return []

    paths = []
    for line in result.stdout.splitlines():
        parts = line.split(None, 1)
        if len(parts) == 2:
            rel = parts[1].strip()
            abs_path = os.path.join(repo_root, rel)
            if os.path.isdir(abs_path) and is_git_repo(abs_path):
                paths.append(abs_path)
    return paths


def submodule_remote_branch(sub_abs: str) -> Optional[str]:
    """
    Return the remote branch name whose tip matches the submodule's current
    HEAD commit. Uses git for-each-ref for compatibility with git 1.8.x+
    (avoids --points-at which requires git 2.7+).
    No network call, no .gitmodules config required.
    """
    head = git_output(["rev-parse", "HEAD"], cwd=sub_abs)
    if not head:
        return None
    refs = git_output(
        ["for-each-ref", "--format=%(refname:short) %(objectname)",
         "refs/remotes/origin/"],
        cwd=sub_abs
    )
    for line in refs.splitlines():
        parts = line.split()
        if len(parts) != 2:
            continue
        refname, sha = parts
        if sha == head and refname.startswith("origin/"):
            branch = refname[len("origin/"):]
            # skip the HEAD alias
            if branch == "HEAD":
                continue
            return branch
    return None


def build_repo_tree(root: str) -> List[str]:
    """
    Recursively collect all repos (root + submodules) in bottom-up order
    (leaves first, root last). This is the correct order for commit/push.
    """
    result = []
    for sub in get_submodule_paths(root):
        result.extend(build_repo_tree(sub))
    result.append(root)
    return result


def build_repo_tree_topdown(root: str) -> List[str]:
    """Top-down order (root first). Used for status/fetch/diff/log."""
    result = [root]
    for sub in get_submodule_paths(root):
        result.extend(build_repo_tree_topdown(sub))
    return result


def find_invocation_root(start: str) -> str:
    """
    Return the toplevel of the git repo containing start.
    mgit intentionally does not walk up into parent repos — running mgit
    from inside a submodule operates on that submodule tree only.
    """
    toplevel = get_toplevel(start)
    if toplevel is None:
        die("Not inside a git repository: {}".format(start))
    return toplevel

# ---------------------------------------------------------------------------
# Editor helper
# ---------------------------------------------------------------------------

def resolve_editor(cwd: str = None) -> str:
    """
    Return the editor to use for commit messages.
    Resolution order (mirrors git's own logic):
      GIT_EDITOR env var
      → core.editor git config
      → VISUAL env var
      → EDITOR env var
      → notepad (Windows) / nano (Unix) as last resort
    """
    editor = (
        os.environ.get("GIT_EDITOR")
        or git_output(["config", "--get", "core.editor"], cwd=cwd)
        or os.environ.get("VISUAL")
        or os.environ.get("EDITOR")
        or ("notepad" if IS_WINDOWS else "nano")
    )
    return editor


def open_editor_for_message(repo_label: str, cwd: str = None) -> str:
    """
    Open the configured editor with a temp file pre-seeded with a context
    comment, wait for the user to save and exit, then return the message
    with comment lines stripped.

    Returns '' if the user saves an empty or comment-only file (aborts
    the commit for that repo, consistent with git behaviour).
    """
    editor = resolve_editor(cwd=cwd)

    # Build the template — context header so the user knows which repo
    template = (
        "\n"
        "# Please enter the commit message for: {}\n"
        "# Lines starting with '#' will be ignored.\n"
        "# An empty message aborts the commit for this repo.\n"
    ).format(repo_label)

    # Use a .txt extension so Notepad on Windows opens without complaints
    suffix = ".txt" if IS_WINDOWS else ".git-commit-msg"
    fd, tmp_path = tempfile.mkstemp(prefix="mgit-msg-", suffix=suffix)
    try:
        with os.fdopen(fd, "w", newline="\n") as f:
            f.write(template)

        # On Windows, shlex.split isn't reliable for paths with spaces;
        # pass the editor+path as a single shell string so cmd.exe handles it.
        if IS_WINDOWS:
            ret = subprocess.call("{} {}".format(editor, tmp_path), shell=True)
        else:
            import shlex
            ret = subprocess.call(shlex.split(editor) + [tmp_path])

        if ret != 0:
            die("Editor exited with code {}. Aborting.".format(ret))

        with open(tmp_path, "r", encoding="utf-8", newline=None) as f:
            raw = f.read()
    finally:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass

    # Strip comment lines and normalise line endings
    lines = [l.rstrip("\r") for l in raw.splitlines()
             if not l.lstrip().startswith("#")]
    return "\n".join(lines).strip()

# ---------------------------------------------------------------------------
# Signing helpers
# ---------------------------------------------------------------------------

def should_skip_signing(cwd: str = None) -> Tuple[bool, str]:
    """
    Check git config user.email in the given repo against the no-sign list.
    Returns (skip: bool, reason: str).
    """
    email = git_output(["config", "user.email"], cwd=cwd).lower()
    if not email:
        return False, ""

    for pattern in CONFIG.no_sign_emails:
        try:
            if re.fullmatch(pattern, email, re.IGNORECASE):
                return True, "email '{}' matches no-sign pattern '{}'".format(
                    email, pattern)
        except re.error:
            if fnmatch.fnmatch(email, pattern.lower()):
                return True, "email '{}' matches no-sign glob '{}'".format(
                    email, pattern)

    return False, ""


def check_gpg_available(cwd: str = None) -> None:
    """
    Verify that GPG signing can actually work before touching any repo.
    GPG signing is driven entirely by git config (commit.gpgsign / user.signingkey);
    mgit never injects -S itself. This function is a pre-flight sanity check only.
    Dies with a clear message if the config looks broken.
    """
    key      = git_output(["config", "--get", "user.signingkey"], cwd=cwd)
    gpg_sign = git_output(["config", "--get", "commit.gpgsign"],  cwd=cwd)

    # gpg_sign is '' when unset; treat that as "not enabled"
    if not key and gpg_sign.lower() not in ("true", "1", "yes"):
        die(
            "GPG signing is enabled in git config but no signing key is set.\n"
            "       Set one with: git config --global user.signingkey <KEYID>\n"
            "       Or disable auto-signing: git config --global commit.gpgsign false\n"
            "       To skip signing for AI agents, ensure user.email matches\n"
            "       a known bot pattern (see ~/.mgitconfig)."
        )

    gpg_prog = git_output(["config", "--get", "gpg.program"], cwd=cwd) or "gpg"
    if not shutil.which(gpg_prog):
        die("GPG signing is configured but '{}' was not found in PATH.\n"
            "       Install GPG or set gpg.program to the correct binary.".format(gpg_prog))

# ---------------------------------------------------------------------------
# Working-tree state helpers
# ---------------------------------------------------------------------------

def has_staged_changes(cwd: str) -> bool:
    """Return True if there are changes staged in the index."""
    result = subprocess.run(
        ["git", "diff", "--cached", "--quiet"],
        cwd=cwd, stdout=subprocess.PIPE, stderr=subprocess.PIPE
    )
    return result.returncode != 0


def has_any_changes(cwd: str) -> bool:
    """Return True if working tree or index has any modifications."""
    result = subprocess.run(
        ["git", "status", "--porcelain"],
        cwd=cwd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, encoding="utf-8",
        universal_newlines=True
    )
    return bool(result.stdout.strip())


def submodule_refs_dirty(parent: str) -> bool:
    """
    Return True if any submodule ref in parent's index differs from HEAD
    (i.e. submodule was updated and parent needs a ref-update commit).
    """
    result = subprocess.run(
        ["git", "submodule", "status"],
        cwd=parent,
        stdout=subprocess.PIPE, stderr=subprocess.PIPE, encoding="utf-8",
        universal_newlines=True
    )
    for line in result.stdout.splitlines():
        # !!! TODO : Will it still work with i18n/l10n? !!!
        if line.startswith("+"):
            return True
    return False

