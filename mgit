#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
mgit - Multi-repo Git automation tool
Recursively manages git repositories with submodules,
handling commit ordering, signing enforcement, and ref updates.

Requires: Python 3.6+, git (stock), bash (stock)
Tested on: CentOS 7, Ubuntu 18+
"""

from __future__ import print_function

import os
import re
import sys
import shutil
import tempfile
import fnmatch
import argparse
import configparser
import subprocess
from typing import List, Optional, Tuple, Dict

# ---------------------------------------------------------------------------
# Defaults (overridable via .mgitconfig)
# ---------------------------------------------------------------------------

VERSION = "1.1.0"

DEFAULT_REF_COMMIT_MSG = "chore: update submodule refs"

# Exact or regex patterns for emails that should NOT be GPG-signed.
# These are known AI agent / bot identities. Patterns are matched as
# case-insensitive full-string regex against git config user.email.
DEFAULT_NO_SIGN_EMAILS: List[str] = [
    # Claude (Anthropic)
    r"242468646\+claude@users\.noreply\.github\.com",
    r"claude\[bot\]@users\.noreply\.github\.com",
    r"noreply@anthropic\.com",
    # GitHub Copilot
    r"198982749\+copilot@users\.noreply\.github\.com",
    # GitHub Actions built-in
    r"41898282\+github-actions\[bot\]@users\.noreply\.github\.com",
    # OpenAI Codex variants
    r"codex@example\.com",                # bad default that ships with Codex CLI
    r"noreply@codex\.openai\.com",        # proposed official
    r"199175422\+chatgpt-codex-connector\[bot\]@users\.noreply\.github\.com",
    # Google Gemini
    r"218195315\+gemini-cli@users\.noreply\.github\.com",
    r"gemini-code-assist\[bot\]@.*",
    r"noreply@gemini\.google\.com",
    # Generic catch-all: any GitHub-hosted [bot] account
    r".*\[bot\]@users\.noreply\.github\.com",
]

# ---------------------------------------------------------------------------
# Config loader
# ---------------------------------------------------------------------------

class MgitConfig:
    """
    Loads .mgitconfig from (in order):
      1. cwd
      2. ~/.mgitconfig
      3. Built-in defaults
    """

    def __init__(self) -> None:
        self.ref_commit_msg: str = DEFAULT_REF_COMMIT_MSG
        self.no_sign_emails: List[str] = list(DEFAULT_NO_SIGN_EMAILS)
        self.verbose: bool = False
        self._load()

    def _load(self) -> None:
        candidates = [
            os.path.join(os.getcwd(), ".mgitconfig"),
            os.path.expanduser("~/.mgitconfig"),
        ]
        parser = configparser.ConfigParser()
        for path in candidates:
            if os.path.isfile(path):
                parser.read(path)
                break  # first found wins

        if parser.has_option("refs", "commit_msg"):
            self.ref_commit_msg = parser.get("refs", "commit_msg").strip('"\'')

        if parser.has_option("signing", "no_sign_emails"):
            raw = parser.get("signing", "no_sign_emails")
            extras = [e.strip() for e in raw.splitlines() if e.strip()]
            # Append to defaults, not replace
            self.no_sign_emails.extend(extras)

        if parser.has_option("behavior", "verbose"):
            self.verbose = parser.getboolean("behavior", "verbose")


CONFIG = MgitConfig()

# ---------------------------------------------------------------------------
# Logging helpers
# ---------------------------------------------------------------------------

def info(msg: str) -> None:
    print("[mgit] {}".format(msg), file=sys.stderr)

def verbose(msg: str) -> None:
    if CONFIG.verbose:
        print("[mgit] {}".format(msg), file=sys.stderr)

def warn(msg: str) -> None:
    print("[mgit] WARN: {}".format(msg), file=sys.stderr)

def error(msg: str) -> None:
    print("[mgit] ERROR: {}".format(msg), file=sys.stderr)

def die(msg: str, code: int = 1) -> None:
    error(msg)
    sys.exit(code)

def prompt(msg: str, default: str = "") -> str:
    """Prompt the user for input, with an optional default value."""
    if default:
        display = "{} [{}]: ".format(msg, default)
    else:
        display = "{}: ".format(msg)
    try:
        answer = input(display).strip()
    except (KeyboardInterrupt, EOFError):
        print()
        die("Aborted.")
    return answer if answer else default

def prompt_yes_no(msg: str, default: bool = True) -> bool:
    """Prompt for a yes/no answer. Returns True for yes, False for no."""
    hint = "Y/n" if default else "y/N"
    try:
        answer = input("{} [{}]: ".format(msg, hint)).strip().lower()
    except (KeyboardInterrupt, EOFError):
        print()
        die("Aborted.")
    if not answer:
        return default
    return answer in ("y", "yes")

# ---------------------------------------------------------------------------
# Git subprocess helpers
# ---------------------------------------------------------------------------

def run_git(args: List[str], cwd: str = None, check: bool = True,
            capture: bool = False) -> subprocess.CompletedProcess:
    """Run git with given args in cwd. Streams output unless capture=True."""
    cmd = ["git"] + args
    verbose("  $ {}  [in {}]".format(" ".join(cmd), cwd or os.getcwd()))
    if capture:
        result = subprocess.run(
            cmd, cwd=cwd,
            stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            universal_newlines=True
        )
    else:
        result = subprocess.run(cmd, cwd=cwd)
    if check and result.returncode != 0:
        if capture:
            sys.stderr.write(result.stderr)
        sys.exit(result.returncode)
    return result


def git_output(args: List[str], cwd: str = None) -> str:
    """Run git and return stdout, never raising on error (returns '')."""
    result = run_git(args, cwd=cwd, check=False, capture=True)
    return result.stdout.strip()


def git_ok(args: List[str], cwd: str = None) -> bool:
    """Return True if git command exits 0."""
    result = subprocess.run(
        ["git"] + args, cwd=cwd,
        stdout=subprocess.PIPE, stderr=subprocess.PIPE
    )
    return result.returncode == 0

# ---------------------------------------------------------------------------
# Repository discovery
# ---------------------------------------------------------------------------

def is_git_repo(path: str) -> bool:
    return git_ok(["rev-parse", "--git-dir"], cwd=path)


def get_toplevel(path: str) -> Optional[str]:
    """Return the git toplevel for path, or None if not in a repo."""
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        cwd=path,
        stdout=subprocess.PIPE, stderr=subprocess.PIPE,
        universal_newlines=True
    )
    if result.returncode == 0:
        return result.stdout.strip()
    return None


def get_submodule_paths(repo_root: str) -> List[str]:
    """
    Return list of absolute paths for all direct submodules of repo_root,
    as declared in .gitmodules. Returns [] if none.
    """
    gitmodules = os.path.join(repo_root, ".gitmodules")
    if not os.path.isfile(gitmodules):
        return []

    result = subprocess.run(
        ["git", "config", "--file", ".gitmodules",
         "--get-regexp", r"submodule\..*\.path"],
        cwd=repo_root,
        stdout=subprocess.PIPE, stderr=subprocess.PIPE,
        universal_newlines=True
    )
    if result.returncode != 0:
        return []

    paths = []
    for line in result.stdout.splitlines():
        parts = line.split(None, 1)
        if len(parts) == 2:
            rel = parts[1].strip()
            abs_path = os.path.join(repo_root, rel)
            if os.path.isdir(abs_path) and is_git_repo(abs_path):
                paths.append(abs_path)
    return paths


def build_repo_tree(root: str) -> List[str]:
    """
    Recursively collect all repos (root + submodules) in bottom-up order
    (leaves first, root last). This is the correct order for commit/push.
    """
    result = []
    for sub in get_submodule_paths(root):
        result.extend(build_repo_tree(sub))
    result.append(root)
    return result


def build_repo_tree_topdown(root: str) -> List[str]:
    """
    Top-down order (root first). Used for pull/fetch/status.
    """
    result = [root]
    for sub in get_submodule_paths(root):
        result.extend(build_repo_tree_topdown(sub))
    return result


def find_invocation_root(start: str) -> str:
    """
    Walk up from start to find the highest git repo that contains start
    as a submodule (directly or transitively). If start itself is not
    a submodule of any parent, return start's own toplevel.

    This ensures 'mgit' invoked from a subdir does NOT walk up into a
    parent repo it doesn't own.
    """
    toplevel = get_toplevel(start)
    if toplevel is None:
        die("Not inside a git repository: {}".format(start))
    return toplevel

# ---------------------------------------------------------------------------
# Signing helpers
# ---------------------------------------------------------------------------

def should_skip_signing(cwd: str = None) -> Tuple[bool, str]:
    """
    Check git config user.email in the given repo against the no-sign list.
    Returns (skip: bool, reason: str).
    """
    email = git_output(["config", "user.email"], cwd=cwd).lower()
    if not email:
        return False, ""

    for pattern in CONFIG.no_sign_emails:
        try:
            if re.fullmatch(pattern, email, re.IGNORECASE):
                return True, "email '{}' matches no-sign pattern '{}'".format(
                    email, pattern)
        except re.error:
            # Fall back to fnmatch for simple glob patterns
            if fnmatch.fnmatch(email, pattern.lower()):
                return True, "email '{}' matches no-sign glob '{}'".format(
                    email, pattern)

    return False, ""


def verify_gpg_available(cwd: str = None) -> None:
    """
    Verify that GPG signing will actually work before attempting a commit.
    Dies with a clear message if it won't.
    """
    # Check signing key is configured
    key = git_output(["config", "--get", "user.signingkey"], cwd=cwd)
    gpg_sign = git_output(["config", "--get", "commit.gpgsign"], cwd=cwd)

    # If neither is configured, signing will fail — refuse early
    if not key and gpg_sign.lower() not in ("true", "1", "yes"):
        die(
            "GPG signing is required but no signing key is configured.\n"
            "       Set one with: git config --global user.signingkey <KEYID>\n"
            "       Or configure commit.gpgsign=true with a default key.\n"
            "       To skip signing for AI agents, ensure user.email matches\n"
            "       a known bot pattern (see ~/.mgitconfig)."
        )

    # Also check gpg binary exists
    gpg_prog = git_output(["config", "--get", "gpg.program"], cwd=cwd) or "gpg"
    found = subprocess.run(
        ["which", gpg_prog],
        stdout=subprocess.PIPE, stderr=subprocess.PIPE
    )
    if found.returncode != 0:
        die("GPG signing required but '{}' binary not found in PATH.".format(
            gpg_prog))

# ---------------------------------------------------------------------------
# has_staged_changes / has_unstaged_changes
# ---------------------------------------------------------------------------

def has_staged_changes(cwd: str) -> bool:
    result = subprocess.run(
        ["git", "diff", "--cached", "--quiet"],
        cwd=cwd, stdout=subprocess.PIPE, stderr=subprocess.PIPE
    )
    return result.returncode != 0  # non-zero = there are staged changes


def has_any_changes(cwd: str) -> bool:
    """True if working tree or index has any modifications."""
    result = subprocess.run(
        ["git", "status", "--porcelain"],
        cwd=cwd, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
        universal_newlines=True
    )
    return bool(result.stdout.strip())


def submodule_refs_dirty(parent: str) -> bool:
    """
    Return True if any submodule ref in parent's index differs from HEAD
    (i.e. submodule was updated and parent needs a ref-update commit).
    """
    result = subprocess.run(
        ["git", "submodule", "status"],
        cwd=parent,
        stdout=subprocess.PIPE, stderr=subprocess.PIPE,
        universal_newlines=True
    )
    for line in result.stdout.splitlines():
        if line.startswith("+"):
            return True
    return False

# ---------------------------------------------------------------------------
# gh helpers
# ---------------------------------------------------------------------------

def find_gh() -> Optional[str]:
    """Return the path to the gh binary, or None if not found."""
    result = subprocess.run(
        ["which", "gh"],
        stdout=subprocess.PIPE, stderr=subprocess.PIPE,
        universal_newlines=True
    )
    if result.returncode == 0:
        return result.stdout.strip()
    return None


def offer_gh_install() -> None:
    """
    Print platform-appropriate install instructions for gh and exit.
    Never installs automatically — user's choice.
    """
    import platform
    system = platform.system().lower()

    print()
    print("  'gh' (GitHub CLI) is required for this command but was not found in PATH.")
    print()
    if system == "darwin":
        print("  Install with Homebrew:")
        print("      brew install gh")
    elif system == "linux":
        print("  Install on Debian/Ubuntu:")
        print("      curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \\")
        print("        | sudo dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg")
        print("      echo \"deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] \\")
        print("        https://cli.github.com/packages stable main\" \\")
        print("        | sudo tee /etc/apt/sources.list.d/github-cli.list > /dev/null")
        print("      sudo apt update && sudo apt install gh")
        print()
        print("  Install on CentOS/RHEL/Fedora:")
        print("      sudo dnf install 'dnf-command(config-manager)'")
        print("      sudo dnf config-manager --add-repo https://cli.github.com/packages/rpm/gh-cli.repo")
        print("      sudo dnf install gh")
    elif system == "windows":
        print("  Install with winget:")
        print("      winget install --id GitHub.cli")
        print()
        print("  Or with Scoop:")
        print("      scoop install gh")
    else:
        print("  Download from: https://github.com/cli/cli/releases/latest")

    print()
    print("  After installing, authenticate with: gh auth login")
    print("  Then re-run your mgit command.")
    print()
    sys.exit(1)


def require_gh() -> str:
    """Return gh path or offer install instructions and exit."""
    gh = find_gh()
    if not gh:
        offer_gh_install()
    return gh


def run_gh(args: List[str], check: bool = True,
           capture: bool = False) -> subprocess.CompletedProcess:
    """Run gh with given args."""
    cmd = ["gh"] + args
    verbose("  $ {}".format(" ".join(cmd)))
    if capture:
        result = subprocess.run(
            cmd,
            stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            universal_newlines=True
        )
    else:
        result = subprocess.run(cmd)
    if check and result.returncode != 0:
        if capture:
            sys.stderr.write(result.stderr)
        sys.exit(result.returncode)
    return result


def gh_output(args: List[str]) -> str:
    """Run gh and return stdout."""
    result = run_gh(args, check=False, capture=True)
    return result.stdout.strip()

# ---------------------------------------------------------------------------
# Remote / repo name helpers
# ---------------------------------------------------------------------------

def get_origin_url(cwd: str = None) -> str:
    """Return the origin remote URL, or '' if none."""
    return git_output(["remote", "get-url", "origin"], cwd=cwd)


def repo_name_from_url(url: str) -> str:
    """
    Extract the bare repo name from a remote URL.
    Works for both https://github.com/owner/name.git and git@github.com:owner/name.git
    Returns '' if parsing fails.
    """
    if not url:
        return ""
    # Strip trailing .git
    url = re.sub(r"\.git$", "", url)
    # Last path component
    parts = re.split(r"[/:]", url)
    parts = [p for p in parts if p]
    return parts[-1] if parts else ""


def gh_repo_owner() -> str:
    """Return the authenticated GitHub username via gh, or ''."""
    return gh_output(["api", "user", "--jq", ".login"])

# ---------------------------------------------------------------------------
# detach — split a subdir into its own new GitHub repo and re-add as submodule
# ---------------------------------------------------------------------------

def cmd_detach(root: str, extra_args: List[str]) -> None:
    """
    Detach a subdirectory from the current repo, create a new GitHub repo
    for it, and re-add it as a submodule.

    Usage: mgit detach <subdir>
    """
    # -----------------------------------------------------------------------
    # 0. Parse args
    # -----------------------------------------------------------------------
    if not extra_args:
        die("Usage: mgit detach <subdir>\n"
            "       Detaches a subdirectory into its own repo and adds it as a submodule.")

    subdir_arg = extra_args[0].rstrip("/")

    # Resolve subdir relative to repo root
    subdir_abs = os.path.normpath(os.path.join(root, subdir_arg))
    subdir_rel = os.path.relpath(subdir_abs, root)  # canonical relative path

    # -----------------------------------------------------------------------
    # 1. Validate
    # -----------------------------------------------------------------------
    if not os.path.isdir(subdir_abs):
        die("Subdir not found: {}".format(subdir_abs))

    if not subdir_abs.startswith(root + os.sep):
        die("Subdir must be inside the repo root: {}".format(root))

    # Must not already be a submodule
    existing_subs = get_submodule_paths(root)
    if subdir_abs in existing_subs:
        die("'{}' is already a submodule.".format(subdir_rel))

    # Must not have uncommitted changes in the repo
    if has_any_changes(root):
        die("The repo has uncommitted changes. Please commit or stash them first.")

    # -----------------------------------------------------------------------
    # 2. Require gh
    # -----------------------------------------------------------------------
    require_gh()

    # -----------------------------------------------------------------------
    # 3. Gather info from user
    # -----------------------------------------------------------------------
    origin_url  = get_origin_url(root)
    parent_name = repo_name_from_url(origin_url) or os.path.basename(root)

    print()
    info("Detaching '{}' from '{}' into a new GitHub repo.".format(
        subdir_rel, parent_name))
    print()

    default_repo_name = os.path.basename(subdir_rel)
    repo_name    = prompt("New repo name", default=default_repo_name)
    repo_desc    = prompt("Description (optional)", default="")
    is_public    = prompt_yes_no("Make the new repo public?", default=True)

    # Warn about commit message leaking private repo name
    include_origin = False
    if is_public and origin_url:
        print()
        warn("The parent repo name '{}' will appear in the initial commit message.".format(
            parent_name))
        include_origin = prompt_yes_no(
            "Include parent repo name in initial commit message?", default=False)

    if include_origin:
        initial_commit_msg = "chore: initial commit — split from {}/{}".format(
            parent_name, subdir_rel)
    else:
        initial_commit_msg = "chore: initial commit — split from {}".format(subdir_rel)

    print()
    info("Summary:")
    info("  Subdir       : {}".format(subdir_rel))
    info("  New repo     : {}".format(repo_name))
    info("  Visibility   : {}".format("public" if is_public else "private"))
    info("  Initial msg  : {}".format(initial_commit_msg))
    print()

    if not prompt_yes_no("Proceed?", default=True):
        die("Aborted.", code=0)

    # -----------------------------------------------------------------------
    # 4. Create new git repo in a temp dir and populate it
    # -----------------------------------------------------------------------
    tmpdir = tempfile.mkdtemp(prefix="mgit-detach-")
    info("Working in temp dir: {}".format(tmpdir))

    try:
        # Init
        run_git(["init"], cwd=tmpdir)

        # Copy contents of subdir into temp repo root
        # Use rsync-style copy: contents of subdir_abs go into tmpdir
        for item in os.listdir(subdir_abs):
            src = os.path.join(subdir_abs, item)
            dst = os.path.join(tmpdir, item)
            if os.path.isdir(src):
                shutil.copytree(src, dst)
            else:
                shutil.copy2(src, dst)

        # Stage everything
        run_git(["add", "-A"], cwd=tmpdir)

        # Carry over git identity from parent repo
        user_name  = git_output(["config", "user.name"],  cwd=root)
        user_email = git_output(["config", "user.email"], cwd=root)
        if user_name:
            run_git(["config", "user.name",  user_name],  cwd=tmpdir)
        if user_email:
            run_git(["config", "user.email", user_email], cwd=tmpdir)

        # Commit — apply same signing logic as parent
        skip_sign, reason = should_skip_signing(cwd=root)
        if skip_sign:
            info("Signing skipped for new repo: {}".format(reason))
            run_git(["commit", "-m", initial_commit_msg], cwd=tmpdir)
        else:
            verify_gpg_available(cwd=root)
            run_git(["commit", "-S", "-m", initial_commit_msg], cwd=tmpdir)

        # -----------------------------------------------------------------------
        # 5. Create GitHub repo and push
        # -----------------------------------------------------------------------
        info("Creating GitHub repo '{}'...".format(repo_name))
        visibility_flag = "--public" if is_public else "--private"
        gh_args = ["repo", "create", repo_name, visibility_flag, "--source", tmpdir,
                   "--remote", "origin", "--push"]
        if repo_desc:
            gh_args += ["--description", repo_desc]
        run_gh(gh_args)

        # Retrieve the new repo's URL
        new_repo_url = gh_output(["repo", "view", repo_name, "--json", "sshUrl", "--jq", ".sshUrl"])
        if not new_repo_url:
            # Fallback: construct from owner + name
            owner = gh_repo_owner()
            new_repo_url = "git@github.com:{}/{}.git".format(owner, repo_name)
        info("New repo URL: {}".format(new_repo_url))

    except Exception as e:
        shutil.rmtree(tmpdir, ignore_errors=True)
        die("Failed during new repo setup: {}".format(e))

    finally:
        # Always clean up temp dir
        shutil.rmtree(tmpdir, ignore_errors=True)

    # -----------------------------------------------------------------------
    # 6. Remove subdir from parent and add as submodule
    # -----------------------------------------------------------------------
    info("Removing '{}' from parent repo...".format(subdir_rel))
    run_git(["rm", "-r", subdir_rel], cwd=root)

    info("Adding '{}' as submodule...".format(subdir_rel))
    run_git(["submodule", "add", new_repo_url, subdir_rel], cwd=root)
    run_git(["submodule", "update", "--init", subdir_rel], cwd=root)

    # -----------------------------------------------------------------------
    # 7. Commit the change in parent
    # -----------------------------------------------------------------------
    commit_msg = "chore: detach {} as submodule ({})".format(subdir_rel, repo_name)
    info("Committing detach in parent repo...")

    skip_sign, reason = should_skip_signing(cwd=root)
    if skip_sign:
        info("Signing skipped: {}".format(reason))
        run_git(["commit", "-m", commit_msg], cwd=root)
    else:
        verify_gpg_available(cwd=root)
        run_git(["commit", "-S", "-m", commit_msg], cwd=root)

    print()
    info("Done. '{}' is now a submodule pointing to {}.".format(
        subdir_rel, new_repo_url))
    info("Run 'mgit push' to push both repos.")


# ---------------------------------------------------------------------------
# attach — copy a subdir into an existing submodule repo
# ---------------------------------------------------------------------------

def cmd_attach(root: str, extra_args: List[str]) -> None:
    """
    Attach a subdirectory's contents into an existing submodule repo,
    then remove the subdir from the parent.

    Usage: mgit attach <subdir> <submodule-path>

    The subdir's contents are copied into <submodule-path>, committed
    there, and the original <subdir> is removed from the parent. The
    parent then gets a commit recording both changes.
    """
    # -----------------------------------------------------------------------
    # 0. Parse args
    # -----------------------------------------------------------------------
    if len(extra_args) < 2:
        die("Usage: mgit attach <subdir> <submodule-path>\n"
            "       Moves a subdirectory's contents into an existing submodule.")

    subdir_arg = extra_args[0].rstrip("/")
    target_arg = extra_args[1].rstrip("/")

    subdir_abs = os.path.normpath(os.path.join(root, subdir_arg))
    subdir_rel = os.path.relpath(subdir_abs, root)

    target_abs = os.path.normpath(os.path.join(root, target_arg))
    target_rel = os.path.relpath(target_abs, root)

    # -----------------------------------------------------------------------
    # 1. Validate
    # -----------------------------------------------------------------------
    if not os.path.isdir(subdir_abs):
        die("Subdir not found: {}".format(subdir_abs))

    if not subdir_abs.startswith(root + os.sep):
        die("Subdir must be inside the repo root.")

    # Target must be an existing submodule
    existing_subs = get_submodule_paths(root)
    if target_abs not in existing_subs:
        die("'{}' is not a submodule of this repo.\n"
            "       Available submodules: {}".format(
                target_rel,
                ", ".join(os.path.relpath(s, root) for s in existing_subs) or "(none)"))

    # Subdir must not itself be a submodule
    if subdir_abs in existing_subs:
        die("'{}' is already a submodule — use 'mgit push' to manage it.".format(
            subdir_rel))

    # Must not have uncommitted changes
    if has_any_changes(root):
        die("The repo has uncommitted changes. Please commit or stash them first.")
    if has_any_changes(target_abs):
        die("The target submodule '{}' has uncommitted changes. "
            "Please commit or stash them first.".format(target_rel))

    # -----------------------------------------------------------------------
    # 2. Determine destination inside target submodule
    # -----------------------------------------------------------------------
    # By default, contents go into a subdirectory named after subdir inside target.
    # Ask the user if they want a different destination path within the submodule.
    default_dest_rel = os.path.basename(subdir_rel)
    print()
    info("Attaching '{}' into submodule '{}'.".format(subdir_rel, target_rel))
    print()
    dest_in_target = prompt(
        "Destination path inside '{}' (relative)".format(target_rel),
        default=default_dest_rel
    )
    dest_abs = os.path.normpath(os.path.join(target_abs, dest_in_target))

    if os.path.exists(dest_abs):
        warn("Destination '{}' already exists inside '{}'.".format(
            dest_in_target, target_rel))
        if not prompt_yes_no("Merge/overwrite?", default=False):
            die("Aborted.")

    origin_url  = get_origin_url(root)
    parent_name = repo_name_from_url(origin_url) or os.path.basename(root)
    commit_msg_sub = "chore: attach {}/{} from {}".format(
        target_rel, dest_in_target, parent_name)

    print()
    info("Summary:")
    info("  Source subdir     : {}".format(subdir_rel))
    info("  Target submodule  : {}".format(target_rel))
    info("  Dest in submodule : {}".format(dest_in_target))
    info("  Submodule commit  : {}".format(commit_msg_sub))
    print()

    if not prompt_yes_no("Proceed?", default=True):
        die("Aborted.", code=0)

    # -----------------------------------------------------------------------
    # 3. Copy subdir contents into target submodule
    # -----------------------------------------------------------------------
    info("Copying '{}' into '{}/{}'...".format(
        subdir_rel, target_rel, dest_in_target))

    if os.path.isdir(dest_abs):
        # Merge: copy individual items
        for item in os.listdir(subdir_abs):
            src = os.path.join(subdir_abs, item)
            dst = os.path.join(dest_abs, item)
            if os.path.isdir(src):
                if os.path.exists(dst):
                    shutil.rmtree(dst)
                shutil.copytree(src, dst)
            else:
                shutil.copy2(src, dst)
    else:
        shutil.copytree(subdir_abs, dest_abs)

    # -----------------------------------------------------------------------
    # 4. Commit inside target submodule
    # -----------------------------------------------------------------------
    info("Staging changes in submodule '{}'...".format(target_rel))
    run_git(["add", "-A"], cwd=target_abs)

    if not has_staged_changes(target_abs):
        die("Nothing to commit in submodule '{}' after copy — "
            "destination may already be identical.".format(target_rel))

    skip_sign, reason = should_skip_signing(cwd=target_abs)
    if skip_sign:
        info("Signing skipped for submodule: {}".format(reason))
        run_git(["commit", "-m", commit_msg_sub], cwd=target_abs)
    else:
        verify_gpg_available(cwd=target_abs)
        run_git(["commit", "-S", "-m", commit_msg_sub], cwd=target_abs)

    # -----------------------------------------------------------------------
    # 5. Remove subdir from parent and commit
    # -----------------------------------------------------------------------
    info("Removing '{}' from parent repo...".format(subdir_rel))
    run_git(["rm", "-r", subdir_rel], cwd=root)

    # Stage the updated submodule ref (which now points to the new commit)
    run_git(["add", target_rel], cwd=root)

    commit_msg_parent = "chore: attach {} into submodule {}".format(
        subdir_rel, target_rel)

    info("Committing in parent repo...")
    skip_sign, reason = should_skip_signing(cwd=root)
    if skip_sign:
        info("Signing skipped: {}".format(reason))
        run_git(["commit", "-m", commit_msg_parent], cwd=root)
    else:
        verify_gpg_available(cwd=root)
        run_git(["commit", "-S", "-m", commit_msg_parent], cwd=root)

    print()
    info("Done. '{}' has been moved into submodule '{}/{}'.".format(
        subdir_rel, target_rel, dest_in_target))
    info("Run 'mgit push' to push both repos.")


# ---------------------------------------------------------------------------
# Command implementations
# ---------------------------------------------------------------------------

# --- status -----------------------------------------------------------------

def cmd_status(root: str, extra_args: List[str]) -> None:
    repos = build_repo_tree_topdown(root)
    for repo in repos:
        rel = os.path.relpath(repo, root) if repo != root else "."
        info("=== status: {} ===".format(rel))
        run_git(["status"] + extra_args, cwd=repo, check=False)
        print()


# --- add --------------------------------------------------------------------

def cmd_add(root: str, extra_args: List[str]) -> None:
    """
    In each repo (topdown), run git add with the given args.
    For the primary repo, git add already tracks changed submodule refs,
    so no special handling needed here — refs update happens at push time.
    """
    repos = build_repo_tree_topdown(root)
    for repo in repos:
        rel = os.path.relpath(repo, root) if repo != root else "."
        info("=== add: {} ===".format(rel))
        run_git(["add"] + extra_args, cwd=repo, check=False)


# --- commit -----------------------------------------------------------------

def cmd_commit(root: str, extra_args: List[str]) -> None:
    """
    Commit all repos bottom-up (leaves first, root last).
    - Signing enforced unless email matches no-sign list.
    - Sub-repos committed first; root does NOT auto-update refs here
      (refs update deferred to mgit push).
    - Repos with nothing staged are skipped with a notice.
    """
    repos = build_repo_tree(root)  # bottom-up

    for repo in repos:
        rel = os.path.relpath(repo, root) if repo != root else "."

        if not has_staged_changes(repo):
            verbose("Nothing staged in {}, skipping commit.".format(rel))
            continue

        info("=== commit: {} ===".format(rel))

        skip_sign, reason = should_skip_signing(cwd=repo)
        if skip_sign:
            info("Signing skipped for {}: {}".format(rel, reason))
            commit_args = ["commit"] + extra_args
        else:
            verify_gpg_available(cwd=repo)
            commit_args = ["commit", "-S"] + extra_args

        run_git(commit_args, cwd=repo)


# --- push -------------------------------------------------------------------

def cmd_push(root: str, extra_args: List[str]) -> None:
    """
    Push sequence:
      1. For each submodule (bottom-up): push to its own remote.
      2. Back in root: if submodule refs have changed since last push,
         stage them, make a signed ref-update commit, then push root.
      3. If no ref changes, just push root normally.
    """
    repos = build_repo_tree(root)  # bottom-up
    submodules = repos[:-1]        # everything except root
    parent = repos[-1]             # root

    # Step 1: push all submodules
    for repo in submodules:
        rel = os.path.relpath(repo, root)
        info("=== push submodule: {} ===".format(rel))
        run_git(["push"] + extra_args, cwd=repo)

    # Step 2: update submodule refs in root if needed
    if submodules and submodule_refs_dirty(parent):
        info("Staging updated submodule refs in root repo...")
        run_git(["add"] + [os.path.relpath(s, parent) for s in submodules],
                cwd=parent)

        skip_sign, reason = should_skip_signing(cwd=parent)
        if skip_sign:
            info("Ref-update commit signing skipped: {}".format(reason))
            run_git(["commit", "-m", CONFIG.ref_commit_msg], cwd=parent)
        else:
            verify_gpg_available(cwd=parent)
            run_git(["commit", "-S", "-m", CONFIG.ref_commit_msg], cwd=parent)

    # Step 3: push root
    info("=== push root: {} ===".format(os.path.basename(parent)))
    run_git(["push"] + extra_args, cwd=parent)


# --- pull -------------------------------------------------------------------

def cmd_pull(root: str, extra_args: List[str]) -> None:
    """
    Pull root first, then update submodules recursively.
    After pull, sync submodule URLs and update to recorded SHAs.
    """
    info("=== pull root: {} ===".format(os.path.basename(root)))
    run_git(["pull"] + extra_args, cwd=root)

    subs = get_submodule_paths(root)
    if subs:
        info("Updating submodules...")
        run_git(["submodule", "sync", "--recursive"], cwd=root)
        run_git(["submodule", "update", "--init", "--recursive"], cwd=root)


# --- fetch ------------------------------------------------------------------

def cmd_fetch(root: str, extra_args: List[str]) -> None:
    repos = build_repo_tree_topdown(root)
    for repo in repos:
        rel = os.path.relpath(repo, root) if repo != root else "."
        info("=== fetch: {} ===".format(rel))
        run_git(["fetch"] + extra_args, cwd=repo, check=False)


# --- diff -------------------------------------------------------------------

def cmd_diff(root: str, extra_args: List[str]) -> None:
