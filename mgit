def require_gh() -> None:
    """Exit with install instructions if gh is not available."""
    if not find_gh():
        offer_gh_install()


def _gh_env() -> dict:
    """
    Return an environment dict for gh subprocesses, handling the common
    situation where GITHUB_TOKEN holds a fine-grained PAT for API use
    while gh CLI needs a classic PAT with repo + read:org scopes.

    Resolution order:

    1. [gh] token in .mgitconfig / ~/.mgitconfig
       Inject as GH_TOKEN (beats GITHUB_TOKEN in gh's own priority order).
       This is the recommended option when GITHUB_TOKEN is already in use.

    2. GH_TOKEN already set in the environment
       Leave everything alone — the caller set it deliberately.

    3. GITHUB_TOKEN set but no GH_TOKEN / config token
       Strip GITHUB_TOKEN from the subprocess environment so gh falls
       through to the credential stored by 'gh auth login' (system
       keychain on macOS/Windows, ~/.config/gh/hosts.yml on Linux).
       Rationale: GH_TOKEN is gh CLI's own preferred variable; GITHUB_TOKEN
       is the conventional name for API tokens (GitHub Actions, SDKs, etc.).
       When only GITHUB_TOKEN is present it is almost always a fine-grained
       token scoped for API work, not for gh CLI org/repo operations.

    4. Neither token set
       Leave the environment alone; gh does its own resolution (keychain,
       hosts.yml, interactive prompt).
    """
    env = os.environ.copy()

    if CONFIG.gh_token:
        # Explicit token in .mgitconfig — takes priority over everything.
        env["GH_TOKEN"] = CONFIG.gh_token
        return env

    if env.get("GH_TOKEN"):
        # Caller deliberately set GH_TOKEN — leave it alone.
        return env

    if env.get("GITHUB_TOKEN"):
        # GITHUB_TOKEN present but no gh-specific token configured.
        # Remove it so gh falls through to the gh auth login credential
        # rather than using what is almost certainly a fine-grained API token.
        del env["GITHUB_TOKEN"]

    return env


def _gh_explain_403(stderr_text: str) -> None:
    """
    If gh stderr contains a 403 / permission error, print an actionable
    explanation and exit. Called by run_gh when gh returns non-zero.
    """
    text = stderr_text.lower()
    if "403" in text or "forbidden" in text or "resource not accessible" in text \
            or "token cannot" in text or "must have push access" in text \
            or "not found" in text:
        print()
        error("GitHub API returned a permission error (HTTP 403 / 404).")
        print("[mgit]", file=sys.stderr)
        print("[mgit] Possible causes:", file=sys.stderr)
        print("[mgit]   1. The token being used is a fine-grained personal access token.", file=sys.stderr)
        print("[mgit]      Fine-grained tokens cannot create org repos or list org", file=sys.stderr)
        print("[mgit]      memberships. Use a classic token with repo + read:org scopes.", file=sys.stderr)
        print("[mgit]", file=sys.stderr)
        print("[mgit]   2. No gh token is configured and GITHUB_TOKEN in your environment", file=sys.stderr)
        print("[mgit]      is a fine-grained token scoped for other purposes.", file=sys.stderr)
        print("[mgit]", file=sys.stderr)
        print("[mgit] Fix — add a classic token to ~/.mgitconfig:", file=sys.stderr)
        print("[mgit]      [gh]", file=sys.stderr)
        print("[mgit]      token = ghp_yourclassictoken", file=sys.stderr)
        print("[mgit]", file=sys.stderr)
        print("[mgit] Or set GH_TOKEN for this session only:", file=sys.stderr)
        print("[mgit]      export GH_TOKEN=ghp_yourclassictoken   # Linux / macOS", file=sys.stderr)
        print("[mgit]      $env:GH_TOKEN='ghp_yourclassictoken'   # Windows PowerShell", file=sys.stderr)
        print("[mgit]", file=sys.stderr)
        print("[mgit] Classic token scopes required: repo, read:org, gist", file=sys.stderr)
        print("[mgit] Create one at: https://github.com/settings/tokens", file=sys.stderr)
        print(file=sys.stderr)
        sys.exit(1)


def run_gh(args: List[str], check: bool = True,
           capture: bool = False) -> subprocess.CompletedProcess:
    """
    Run gh with given args.

    If [gh] token is set in .mgitconfig, it is injected as GH_TOKEN into
    the subprocess environment so that gh uses the classic PAT for all
    detach/attach operations, regardless of any GITHUB_TOKEN that may be
    set in the caller's environment for other purposes.
    """
    cmd = ["gh"] + args
    verbose("  $ {}".format(" ".join(cmd)))
    env = _gh_env()
    if capture:
        result = subprocess.run(
            cmd,
            stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            universal_newlines=True,
            env=env
        )
    else:
        result = subprocess.run(cmd, env=env)
    if check and result.returncode != 0:
        if capture:
            sys.stderr.write(result.stderr)
            _gh_explain_403(result.stderr)
        else:
            # Re-run capturing stderr so we can inspect it for 403
            result2 = subprocess.run(
                cmd,
                stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                universal_newlines=True,
                env=env
            )
            if result2.stderr:
                sys.stderr.write(result2.stderr)
            _gh_explain_403(result2.stderr)
        sys.exit(result.returncode)
    return result


def gh_output(args: List[str]) -> str:
    """Run gh and return stdout."""
    result = run_gh(args, check=False, capture=True)
    return result.stdout.strip()

# ---------------------------------------------------------------------------
# Remote / repo name helpers
# ---------------------------------------------------------------------------

def get_origin_url(cwd: str = None) -> str:
    """Return the origin remote URL, or '' if none."""
    return git_output(["remote", "get-url", "origin"], cwd=cwd)


def repo_name_from_url(url: str) -> str:
    """
    Extract the bare repo name from a remote URL.
    Handles both https://github.com/owner/name.git and git@github.com:owner/name.git.
    Returns '' if parsing fails.
    """
    if not url:
        return ""
    url = re.sub(r"\.git$", "", url)
    parts = [p for p in re.split(r"[/:]", url) if p]
    return parts[-1] if parts else ""


def repo_owner_from_url(url: str) -> str:
    """
    Extract the owner (user or org) from a remote URL.
    Handles both https://github.com/owner/name.git and git@github.com:owner/name.git.
    Returns '' if parsing fails.
    """
    if not url:
        return ""
    url = re.sub(r"\.git$", "", url)
    parts = [p for p in re.split(r"[/:]", url) if p]
    # parts looks like: ['github.com', 'owner', 'name']
    return parts[-2] if len(parts) >= 2 else ""


def gh_repo_owner() -> str:
    """Return the authenticated GitHub username via gh, or ''."""
    return gh_output(["api", "user", "--jq", ".login"])


def gh_user_orgs() -> List[str]:
    """
    Return a list of org login names that the authenticated user belongs to.
    Returns [] if the user has no org memberships or if the token does not
    have read:org scope (e.g. a fine-grained PAT).
    """
    result = run_gh(
        ["org", "list", "--limit", "100", "--json", "login", "--jq", ".[].login"],
        check=False, capture=True
    )
    if result.returncode != 0:
        # Token may lack read:org — silently return empty; caller handles it.
        return []
    return [line.strip() for line in result.stdout.splitlines() if line.strip()]


def gh_get_owner(cwd: str = None) -> str:
    """
    Determine the GitHub owner (user or org) for a new repository.

    - Fetches the authenticated user's login and their org memberships.
    - If the user has no org memberships, returns their personal login
      immediately without prompting.
    - Otherwise presents a numbered menu: personal account first, then
      each org, and returns the selected login.

    Personal is always the authenticated gh user — never inferred from
    the current repo's remote URL.
    """
    gh_user = gh_repo_owner()
    if not gh_user:
        die("Could not determine authenticated GitHub user. "
            "Check that gh is authenticated (gh auth status).")

    orgs = gh_user_orgs()

    if not orgs:
        return gh_user

    choices = [gh_user] + orgs
    print()
    info("Where should the new repo be created?")
    for i, name in enumerate(choices, 1):
        label = "(personal)" if i == 1 else "(org)"
        print("  {:2d}. {} {}".format(i, name, label), file=sys.stderr)
    print(file=sys.stderr)

    while True:
        raw = prompt("Select owner [1-{}]".format(len(choices)), default="1")
        try:
            idx = int(raw) - 1
            if 0 <= idx < len(choices):
                return choices[idx]
        except ValueError:
            pass
        warn("Please enter a number between 1 and {}.".format(len(choices)))

# ---------------------------------------------------------------------------
# Shared commit helper
# ---------------------------------------------------------------------------

def do_commit(repo: str, rel: str, msg: str, is_bot: bool,
              bot_reason: str) -> bool:
    """
    Run git commit in repo. Signing is driven by git config (commit.gpgsign);
    mgit's only role is to suppress it for known bots via --no-gpg-sign.

    Returns True if the commit was made, False if the user chose to skip
    (only possible when gpgsign is unset and the user declines to continue).
    """
    if is_bot:
        info("Signing suppressed for {}: {}".format(rel, bot_reason))
        run_git(["commit", "--no-gpg-sign", "-m", msg], cwd=repo)
        return True

    gpg_sign = git_output(["config", "--get", "commit.gpgsign"], cwd=repo)

    if gpg_sign.lower() in ("true", "1", "yes"):
        # Signing is explicitly enabled — verify GPG is usable, then commit
        check_gpg_available(cwd=repo)
        run_git(["commit", "-m", msg], cwd=repo)
        return True

    # commit.gpgsign is not set — commits will be unsigned.
    # Warn the human and ask whether to proceed. Default is yes so that
    # automated / non-interactive use (e.g. pipes) continues safely.
    warn("commit.gpgsign is not set for '{}' — this commit will be unsigned.".format(rel))
    print("[mgit]        To enable signing: git config --global commit.gpgsign true", file=sys.stderr)
    if not prompt_yes_no("Continue without signing?", default=True):
        info("Skipping commit for {}.".format(rel))
        return False

    run_git(["commit", "-m", msg], cwd=repo)
    return True

# ---------------------------------------------------------------------------
# detach — split a subdir into its own new GitHub repo and re-add as submodule
# ---------------------------------------------------------------------------

def _parse_detach_args(root: str, extra_args: List[str]):
    """
    Parse extra_args for cmd_detach and return a normalised descriptor:

        (source_items, subdir_abs, subdir_rel, dest_subdir, repo_name_default)

    source_items  : list of absolute paths to copy into the new repo
    subdir_abs    : absolute path of the directory being detached
                    (= the parent dir when flat/glob mode is used)
    subdir_rel    : repo-relative version of subdir_abs
    dest_subdir   : name of the wrapper folder inside the new repo,
                    or '' for a flat copy
    repo_name_default : suggested default for the repo name prompt

    Supported call forms
    --------------------
    Single directory — dest_subdir defaults to the last path segment:
        mgit detach gui_frontend/src/jcom

    Single directory with trailing slash — flat copy, no wrapper:
        mgit detach gui_frontend/src/jcom/

    Multiple paths (shell glob expansion) — flat copy, repo name default
    derived from the common parent directory:
        mgit detach gui_frontend/src/jcom/*

    Explicit flags (override the above defaults):
        --dest-subdir <name>   wrap contents in <name>/ inside the new repo
        --dest-subdir=<name>   same, alternate syntax
        --no-dest-subdir       flat copy regardless of trailing slash
    """
    USAGE = (
        "Usage: mgit detach <subdir>\n"
        "       mgit detach <subdir>/          (flat — no wrapper subdir)\n"
        "       mgit detach <subdir>/*         (flat — shell glob, same effect)\n"
        "       mgit detach <subdir> --dest-subdir <name>\n"
        "       mgit detach <subdir> --no-dest-subdir"
    )

    if not extra_args:
        die(USAGE)

    # -----------------------------------------------------------------------
    # Strip --dest-subdir / --no-dest-subdir flags from args
    # -----------------------------------------------------------------------
    flag_dest_subdir = None   # None = not specified; '' = no-subdir; str = name
    remaining = []
    i = 0
    while i < len(extra_args):
        a = extra_args[i]
        if a == "--no-dest-subdir":
            flag_dest_subdir = ""
        elif a == "--dest-subdir" and i + 1 < len(extra_args):
            flag_dest_subdir = extra_args[i + 1].strip("/\\")
            i += 1
        elif a.startswith("--dest-subdir="):
            flag_dest_subdir = a[len("--dest-subdir="):].strip("/\\")
        else:
            remaining.append(a)
        i += 1

    if not remaining:
        die(USAGE)

    # -----------------------------------------------------------------------
    # Determine mode from remaining args
    # -----------------------------------------------------------------------
    # Normalise each path: resolve relative to root, strip trailing separators
    abs_paths = []
    for p in remaining:
        # Strip trailing slashes AFTER recording whether the original had one
        abs_paths.append(os.path.normpath(os.path.join(root, p)))

    # Check for trailing slash on original single argument — flat mode signal
    original_had_trailing_slash = (
        len(remaining) == 1
        and remaining[0].endswith(("/", "\\"))
        and not remaining[0].rstrip("/\\") == ""
    )

    if len(remaining) == 1:
        # -----------------------------------------------------------------------
        # Single-path form: mgit detach <subdir>  or  mgit detach <subdir>/
        # -----------------------------------------------------------------------
        subdir_abs = abs_paths[0]
        subdir_rel = os.path.relpath(subdir_abs, root)

        if not os.path.isdir(subdir_abs):
            die("Subdir not found: {}".format(subdir_abs))
        if not subdir_abs.startswith(root + os.sep):
            die("Subdir must be inside the repo root: {}".format(root))
        if subdir_abs in get_submodule_paths(root):
            die("'{}' is already a submodule.".format(subdir_rel))

        source_items = [os.path.join(subdir_abs, n) for n in os.listdir(subdir_abs)]
        repo_name_default = os.path.basename(subdir_abs)

        if flag_dest_subdir is not None:
            # Explicit flag overrides everything
            dest_subdir = flag_dest_subdir
        elif original_had_trailing_slash:
            # Trailing slash → user explicitly asked for flat
            dest_subdir = ""
        else:
            # Default: wrap in a subdir named after the directory
            dest_subdir = os.path.basename(subdir_abs)

    else:
        # -----------------------------------------------------------------------
        # Multi-path form: mgit detach <subdir>/*  (shell glob expansion)
        # All paths must exist and share the same parent directory.
        # -----------------------------------------------------------------------
        for p in abs_paths:
            if not os.path.exists(p):
                die("Path not found: {}".format(p))

        parents = set(os.path.dirname(p) for p in abs_paths)
        if len(parents) != 1:
            die("All paths passed to mgit detach must share the same parent directory.\n"
                "       Got parents: {}".format(", ".join(sorted(parents))))

        common_parent = parents.pop()
        if not common_parent.startswith(root + os.sep) and common_parent != root:
            die("Paths must be inside the repo root: {}".format(root))

        subdir_abs = common_parent
        subdir_rel = os.path.relpath(subdir_abs, root)

        # Verify the parent is not already a submodule
        if subdir_abs in get_submodule_paths(root):
            die("'{}' is already a submodule.".format(subdir_rel))

        source_items = abs_paths
        repo_name_default = os.path.basename(common_parent)

        # Multi-path (glob) form is always flat unless explicitly overridden
        dest_subdir = flag_dest_subdir if flag_dest_subdir is not None else ""

    return source_items, subdir_abs, subdir_rel, dest_subdir, repo_name_default


def _copy_items(source_items: List[str], dest_root: str) -> None:
    """Copy a list of files/directories into dest_root."""
    for src in source_items:
        name = os.path.basename(src)
        dst  = os.path.join(dest_root, name)
        if os.path.isdir(src):
            shutil.copytree(src, dst)
        else:
            shutil.copy2(src, dst)


def cmd_detach(root: str, extra_args: List[str]) -> None:
    """
    Detach a subdirectory from the current repo, create a new GitHub repo
    for it, and re-add it as a submodule.

    Supported forms:
      mgit detach <subdir>
          Contents are wrapped in a <subdir-name>/ folder inside the new repo
          (e.g. detaching jcom/ creates a repo whose root contains jcom/).

      mgit detach <subdir>/
          Trailing slash — flat copy, contents go directly to the repo root.

      mgit detach <subdir>/*
          Shell glob expansion — flat copy from the named items; repo name
          default is derived from the common parent directory.

      mgit detach <subdir> --dest-subdir <name>
          Wrap contents in <name>/ regardless of trailing slash.

      mgit detach <subdir> --no-dest-subdir
          Flat copy regardless of trailing slash.

    The new repo can be created under the authenticated user's personal
    account or any GitHub organisation they belong to. mgit prompts for
    the owner when org memberships are detected.

    Token requirements for gh CLI:
      - Classic personal access token with scopes: repo, read:org, gist
      - Fine-grained tokens cannot list org memberships or create org repos.
    See README.md § "GitHub CLI authentication" for setup options.
    """
    # -----------------------------------------------------------------------
    # Parse arguments
    # -----------------------------------------------------------------------
    source_items, subdir_abs, subdir_rel, dest_subdir, repo_name_default = \
        _parse_detach_args(root, extra_args)

    if has_any_changes(root):
        die("The repo has uncommitted changes. Please commit or stash them first.")

    require_gh()

    # -----------------------------------------------------------------------
    # Gather info from user
    # -----------------------------------------------------------------------
    origin_url  = get_origin_url(root)
    parent_name = repo_name_from_url(origin_url) or os.path.basename(root)

    print()
    info("Detaching '{}' from '{}' into a new GitHub repo.".format(
        subdir_rel, parent_name))
    if dest_subdir:
        info("Contents will be placed under '{}/'' in the new repo.".format(dest_subdir))
    else:
        info("Contents will be placed flat at the new repo root.")

    # Determine owner — personal account or an org
    owner = gh_get_owner(cwd=root)

    print()
    repo_name = prompt("New repo name", default=repo_name_default)
    repo_desc = prompt("Description (optional)", default="")
    is_public = prompt_yes_no("Make the new repo public?", default=True)

    include_origin = False
    if is_public and origin_url:
        print()
        warn("The parent repo name '{}' may appear in the initial commit message.".format(
            parent_name))
        include_origin = prompt_yes_no(
            "Include parent repo name in initial commit message?", default=False)

    if include_origin:
        initial_commit_msg = "chore: initial commit — split from {}/{}".format(
            parent_name, subdir_rel)
    else:
        initial_commit_msg = "chore: initial commit — split from {}".format(subdir_rel)

    qualified_name = "{}/{}".format(owner, repo_name)

    print()
    info("Summary:")
    info("  Subdir      : {}".format(subdir_rel))
    info("  New repo    : {}".format(qualified_name))
    info("  Layout      : {}".format(
        "{}/  (wrapped)".format(dest_subdir) if dest_subdir else "(flat)"))
    info("  Visibility  : {}".format("public" if is_public else "private"))
    info("  Initial msg : {}".format(initial_commit_msg))
    print()

    if not prompt_yes_no("Proceed?", default=True):
        die("Aborted.", code=0)

    # -----------------------------------------------------------------------
    # Build new repo in a temp dir
    # -----------------------------------------------------------------------
    tmpdir = tempfile.mkdtemp(prefix="mgit-detach-")
    new_repo_url = ""
    info("Working in temp dir: {}".format(tmpdir))

    try:
        run_git(["init"], cwd=tmpdir)

        # Determine copy destination — flat or wrapped in a subdir
        if dest_subdir:
            copy_dest = os.path.join(tmpdir, dest_subdir)
            os.makedirs(copy_dest)
        else:
            copy_dest = tmpdir

        _copy_items(source_items, copy_dest)

        run_git(["add", "-A"], cwd=tmpdir)

        # Carry over git identity from parent
        user_name  = git_output(["config", "user.name"],  cwd=root)
        user_email = git_output(["config", "user.email"], cwd=root)
        if user_name:
            run_git(["config", "user.name",  user_name],  cwd=tmpdir)
        if user_email:
            run_git(["config", "user.email", user_email], cwd=tmpdir)

        skip_sign, reason = should_skip_signing(cwd=root)
        do_commit(tmpdir, "(new repo)", initial_commit_msg, skip_sign, reason)

        # Create GitHub repo and push
        info("Creating GitHub repo '{}'...".format(qualified_name))
        visibility_flag = "--public" if is_public else "--private"
        gh_args = ["repo", "create", qualified_name, visibility_flag,
                   "--source", tmpdir, "--remote", "origin", "--push"]
        if repo_desc:
            gh_args += ["--description", repo_desc]
        run_gh(gh_args)

        new_repo_url = gh_output(
            ["repo", "view", qualified_name, "--json", "sshUrl", "--jq", ".sshUrl"])
        if not new_repo_url:
            new_repo_url = "git@github.com:{}/{}.git".format(owner, repo_name)
        info("New repo URL: {}".format(new_repo_url))

    except Exception as e:
        die("Failed during new repo setup: {}".format(e))

    finally:
        shutil.rmtree(tmpdir, ignore_errors=True)

    # -----------------------------------------------------------------------
    # Wire up as submodule in parent
    # -----------------------------------------------------------------------
    info("Removing '{}' from parent repo...".format(subdir_rel))
    run_git(["rm", "-r", subdir_rel], cwd=root)

    info("Adding '{}' as submodule...".format(subdir_rel))
    run_git(["submodule", "add", new_repo_url, subdir_rel], cwd=root)
    run_git(["submodule", "update", "--init", subdir_rel], cwd=root)

    commit_msg = "chore: detach {} as submodule ({})".format(subdir_rel, repo_name)
    info("Committing detach in parent repo...")
    skip_sign, reason = should_skip_signing(cwd=root)
    do_commit(root, ".", commit_msg, skip_sign, reason)

    print()
    info("Done. '{}' is now a submodule pointing to {}.".format(
        subdir_rel, new_repo_url))
    info("Run 'mgit push' to push both repos.")


# ---------------------------------------------------------------------------
# attach — move a subdir's contents into an existing submodule
# ---------------------------------------------------------------------------

def cmd_attach(root: str, extra_args: List[str]) -> None:
    """
    Attach a subdirectory's contents into an existing submodule repo,
    then remove the subdir from the parent.

    Usage: mgit attach <subdir> <submodule-path>

    Works regardless of whether the parent repo or the target submodule
    is owned by a personal account or an organisation — no gh API calls
    are made; only local git operations are performed.
    """
    if len(extra_args) < 2:
        die("Usage: mgit attach <subdir> <submodule-path>\n"
            "       Moves a subdirectory's contents into an existing submodule.")

    subdir_abs = os.path.normpath(os.path.join(root, extra_args[0].rstrip("/\\")))
    subdir_rel = os.path.relpath(subdir_abs, root)

    target_abs = os.path.normpath(os.path.join(root, extra_args[1].rstrip("/\\")))
    target_rel = os.path.relpath(target_abs, root)

    # -----------------------------------------------------------------------
    # Validate
    # -----------------------------------------------------------------------
    if not os.path.isdir(subdir_abs):
        die("Subdir not found: {}".format(subdir_abs))

    if not subdir_abs.startswith(root + os.sep):
        die("Subdir must be inside the repo root.")

    existing_subs = get_submodule_paths(root)

    if target_abs not in existing_subs:
        die("'{}' is not a submodule of this repo.\n"
            "       Available submodules: {}".format(
                target_rel,
                ", ".join(os.path.relpath(s, root) for s in existing_subs) or "(none)"))

    if subdir_abs in existing_subs:
        die("'{}' is already a submodule — use 'mgit push' to manage it.".format(
            subdir_rel))

    if has_any_changes(root):
        die("The repo has uncommitted changes. Please commit or stash them first.")
    if has_any_changes(target_abs):
        die("The target submodule '{}' has uncommitted changes. "
            "Please commit or stash them first.".format(target_rel))

    # -----------------------------------------------------------------------
    # Determine destination inside the target submodule
    # -----------------------------------------------------------------------
    print()
    info("Attaching '{}' into submodule '{}'.".format(subdir_rel, target_rel))
    print()

    dest_in_target = prompt(
        "Destination path inside '{}' (relative)".format(target_rel),
        default=os.path.basename(subdir_rel)
    )
    dest_abs = os.path.normpath(os.path.join(target_abs, dest_in_target))

    if os.path.exists(dest_abs):
        warn("Destination '{}' already exists inside '{}'.".format(
            dest_in_target, target_rel))
        if not prompt_yes_no("Merge/overwrite?", default=False):
            die("Aborted.")

    origin_url  = get_origin_url(root)
    parent_name = repo_name_from_url(origin_url) or os.path.basename(root)
    commit_msg_sub = "chore: attach {}/{} from {}".format(
        target_rel, dest_in_target, parent_name)

    print()
    info("Summary:")
    info("  Source subdir     : {}".format(subdir_rel))
    info("  Target submodule  : {}".format(target_rel))
    info("  Dest in submodule : {}".format(dest_in_target))
    info("  Submodule commit  : {}".format(commit_msg_sub))
    print()

    if not prompt_yes_no("Proceed?", default=True):
        die("Aborted.", code=0)

    # -----------------------------------------------------------------------
    # Copy subdir contents into target submodule
    # -----------------------------------------------------------------------
    info("Copying '{}' into '{}/{}'...".format(
        subdir_rel, target_rel, dest_in_target))

    if os.path.isdir(dest_abs):
        for item in os.listdir(subdir_abs):
            src = os.path.join(subdir_abs, item)
            dst = os.path.join(dest_abs, item)
            if os.path.isdir(src):
                if os.path.exists(dst):
                    shutil.rmtree(dst)
                shutil.copytree(src, dst)
            else:
                shutil.copy2(src, dst)
    else:
        shutil.copytree(subdir_abs, dest_abs)

    # -----------------------------------------------------------------------
    # Commit inside the target submodule
    # -----------------------------------------------------------------------
    info("Staging changes in submodule '{}'...".format(target_rel))
    run_git(["add", "-A"], cwd=target_abs)

    if not has_staged_changes(target_abs):
        die("Nothing to commit in submodule '{}' after copy — "
            "destination may already be identical.".format(target_rel))

    skip_sign, reason = should_skip_signing(cwd=target_abs)
    do_commit(target_abs, target_rel, commit_msg_sub, skip_sign, reason)

    # -----------------------------------------------------------------------
    # Remove subdir from parent and commit
    # -----------------------------------------------------------------------
    info("Removing '{}' from parent repo...".format(subdir_rel))
    run_git(["rm", "-r", subdir_rel], cwd=root)

    run_git(["add", target_rel], cwd=root)

    commit_msg_parent = "chore: attach {} into submodule {}".format(
        subdir_rel, target_rel)

    info("Committing in parent repo...")
    skip_sign, reason = should_skip_signing(cwd=root)
    do_commit(root, ".", commit_msg_parent, skip_sign, reason)

    print()
    info("Done. '{}' has been moved into submodule '{}/{}'.".format(
        subdir_rel, target_rel, dest_in_target))
    info("Run 'mgit push' to push both repos.")


# ---------------------------------------------------------------------------
# Standard command implementations
# ---------------------------------------------------------------------------

def cmd_status(root: str, extra_args: List[str]) -> None:
    for repo in build_repo_tree_topdown(root):
        rel = os.path.relpath(repo, root) if repo != root else "."
        info("=== status: {} ===".format(rel))
        run_git(["status"] + extra_args, cwd=repo, check=False)
        print()


def cmd_add(root: str, extra_args: List[str]) -> None:
    """Stage in all repos top-down. Ref updates are deferred to mgit push."""
    for repo in build_repo_tree_topdown(root):
        rel = os.path.relpath(repo, root) if repo != root else "."
        info("=== add: {} ===".format(rel))
        run_git(["add"] + extra_args, cwd=repo, check=False)


def _has_message_flag(args: List[str]) -> bool:
    """Return True if args contains an explicit commit message flag."""
    for a in args:
        if a in ("-m", "--message"):
            return True
        if a.startswith("-m") and len(a) > 2:      # -m"msg"
            return True
        if a.startswith("--message="):              # --message=msg
            return True
    return False


def _extract_message(args: List[str]) -> str:
    """
    Extract the commit message value from args containing -m / --message.
    Handles:  -m "msg"  |  -m"msg"  |  --message "msg"  |  --message=msg
    Returns '' if not found (caller should have checked _has_message_flag first).
    """
    i = 0
    while i < len(args):
        a = args[i]
        if a in ("-m", "--message") and i + 1 < len(args):
            return args[i + 1]
        if a.startswith("-m") and len(a) > 2:
            return a[2:]
        if a.startswith("--message="):
            return a[len("--message="):]
        i += 1
    return ""


def cmd_commit(root: str, extra_args: List[str]) -> None:
    """
    Commit all repos bottom-up (leaves first, root last).

    If -m / --message is supplied, the same message is used for every repo
    that has staged changes.

    If no message flag is given, the configured editor is opened once per
    repo that has staged changes. The editor prompt shows which repo is
    being committed so the user can write an appropriate message. Saving
    an empty message skips that repo (consistent with git behaviour).

    Signing is driven entirely by git config (commit.gpgsign / user.signingkey).
    mgit suppresses signing for known AI agents / bots via --no-gpg-sign.
    """
    has_msg = _has_message_flag(extra_args)

    for repo in build_repo_tree(root):
        rel = os.path.relpath(repo, root) if repo != root else "."

        if not has_staged_changes(repo):
            verbose("Nothing staged in {}, skipping.".format(rel))
            continue

        info("=== commit: {} ===".format(rel))

        if has_msg:
            msg_value = _extract_message(extra_args)
            skip_sign, reason = should_skip_signing(cwd=repo)
            if not do_commit(repo, rel, msg_value, skip_sign, reason):
                continue  # user declined unsigned commit
        else:
            # No -m: open editor so the user can write a per-repo message
            msg = open_editor_for_message(rel, cwd=repo)
            if not msg:
                info("Empty message — skipping commit for {}.".format(rel))
                continue
            skip_sign, reason = should_skip_signing(cwd=repo)
            if not do_commit(repo, rel, msg, skip_sign, reason):
                continue  # user declined unsigned commit


def cmd_push(root: str, extra_args: List[str]) -> None:
    """
    Push sequence (bottom-up):
      1. Push every submodule to its own remote.
      2. If submodule refs changed, stage + commit them in root.
      3. Push root.
    """
    repos      = build_repo_tree(root)
    submodules = repos[:-1]
    parent     = repos[-1]

    for repo in submodules:
        rel = os.path.relpath(repo, root)
        info("=== push submodule: {} ===".format(rel))
        run_git(["push"] + extra_args, cwd=repo)

    if submodules and submodule_refs_dirty(parent):
        info("Staging updated submodule refs in root repo...")
        run_git(["add"] + [os.path.relpath(s, parent) for s in submodules],
                cwd=parent)
        skip_sign, reason = should_skip_signing(cwd=parent)
        do_commit(parent, ".", CONFIG.ref_commit_msg, skip_sign, reason)

    info("=== push root: {} ===".format(os.path.basename(parent)))
    run_git(["push"] + extra_args, cwd=parent)


def cmd_pull(root: str, extra_args: List[str]) -> None:
    """Pull root, then sync and update all submodules recursively."""
    info("=== pull root: {} ===".format(os.path.basename(root)))
    run_git(["pull"] + extra_args, cwd=root)

    if get_submodule_paths(root):
        info("Updating submodules...")
        run_git(["submodule", "sync", "--recursive"], cwd=root)
        run_git(["submodule", "update", "--init", "--recursive"], cwd=root)


def cmd_fetch(root: str, extra_args: List[str]) -> None:
    for repo in build_repo_tree_topdown(root):
        rel = os.path.relpath(repo, root) if repo != root else "."
        info("=== fetch: {} ===".format(rel))
        run_git(["fetch"] + extra_args, cwd=repo, check=False)


def cmd_diff(root: str, extra_args: List[str]) -> None:
    for repo in build_repo_tree_topdown(root):
        rel = os.path.relpath(repo, root) if repo != root else "."
        info("=== diff: {} ===".format(rel))
