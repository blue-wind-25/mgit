#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
mgit - Multi-repo Git automation tool
Recursively manages git repositories with submodules,
handling commit ordering, signing enforcement, and ref updates.

Requires: Python 3.6+, git (stock)
Zero pip dependencies — stdlib only.
Tested on: CentOS 7, Ubuntu 18+, Windows 10/11 (Git for Windows + Python 3)
"""

from __future__ import print_function

import os
import re
import sys
import shutil
import tempfile
import fnmatch
import configparser
import subprocess
import unicodedata
from typing import List, Optional, Tuple


# ---------------------------------------------------------------------------
# Unicode normalization
# ---------------------------------------------------------------------------
def unorm(s: str) -> str:
    return unicodedata.normalize("NFC", s)

# ---------------------------------------------------------------------------
# Platform detection
# ---------------------------------------------------------------------------

IS_WINDOWS = sys.platform == "win32"

# ---------------------------------------------------------------------------
# Windows UTF-8 console output
# ---------------------------------------------------------------------------
# Force UTF-8 for stdout/stderr on Windows so non-ASCII filenames, repo
# names, and commit messages display correctly regardless of the system
# code page. reconfigure() is Python 3.7+; on 3.6 we silently skip it
# (Python 3.6 is EOL and has no clean stdlib-only UTF-8 console fix).
if IS_WINDOWS and sys.version_info >= (3, 7):
    sys.stdout.reconfigure(encoding="utf-8", errors="replace")  # type: ignore[attr-defined]
    sys.stderr.reconfigure(encoding="utf-8", errors="replace")  # type: ignore[attr-defined]

# ---------------------------------------------------------------------------
# Defaults (overridable via .mgitconfig)
# ---------------------------------------------------------------------------

VERSION = "1.6.0"

DEFAULT_REF_COMMIT_MSG = "chore: update submodule refs"

