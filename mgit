def cmd_status(root: str, extra_args: List[str]) -> None:
    for repo in build_repo_tree_topdown(root):
        rel = os.path.relpath(repo, root) if repo != root else "."
        info("=== status: {} ===".format(rel))
        run_git(["status"] + extra_args, cwd=repo, check=False)
        print()


def cmd_add(root: str, extra_args: List[str]) -> None:
    """Stage in all repos top-down. Ref updates are deferred to mgit push."""
    for repo in build_repo_tree_topdown(root):
        rel = os.path.relpath(repo, root) if repo != root else "."
        info("=== add: {} ===".format(rel))
        run_git(["add"] + extra_args, cwd=repo, check=False)


def _has_message_flag(args: List[str]) -> bool:
    """Return True if args contains an explicit commit message flag."""
    for a in args:
        if a in ("-m", "--message"):
            return True
        if a.startswith("-m") and len(a) > 2:      # -m"msg"
            return True
        if a.startswith("--message="):             # --message=msg
            return True
    return False


def _extract_message(args: List[str]) -> str:
    """
    Extract the commit message value from args containing -m / --message.
    Handles:  -m "msg"  |  -m"msg"  |  --message "msg"  |  --message=msg
    Returns '' if not found (caller should have checked _has_message_flag first).
    """
    i = 0
    while i < len(args):
        a = args[i]
        if a in ("-m", "--message") and i + 1 < len(args):
            return args[i + 1]
        if a.startswith("-m") and len(a) > 2:
            return a[2:]
        if a.startswith("--message="):
            return a[len("--message="):]
        i += 1
    return ""


def cmd_commit(root: str, extra_args: List[str]) -> None:
    """
    Commit all repos bottom-up (leaves first, root last).

    If -m / --message is supplied, the same message is used for every repo
    that has staged changes.

    If no message flag is given, the configured editor is opened once per
    repo that has staged changes. The editor prompt shows which repo is
    being committed so the user can write an appropriate message. Saving
    an empty message skips that repo (consistent with git behaviour).

    Signing is driven entirely by git config (commit.gpgsign / user.signingkey).
    mgit suppresses signing for known AI agents / bots via --no-gpg-sign.
    """
    has_msg = _has_message_flag(extra_args)

    for repo in build_repo_tree(root):
        rel = os.path.relpath(repo, root) if repo != root else "."

        if not has_staged_changes(repo):
            verbose("Nothing staged in {}, skipping.".format(rel))
            continue

        info("=== commit: {} ===".format(rel))

        if has_msg:
            msg_value = _extract_message(extra_args)
            skip_sign, reason = should_skip_signing(cwd=repo)
            if not do_commit(repo, rel, msg_value, skip_sign, reason):
                continue  # user declined unsigned commit
        else:
            # No -m: open editor so the user can write a per-repo message
            msg = open_editor_for_message(rel, cwd=repo)
            if not msg:
                info("Empty message — skipping commit for {}.".format(rel))
                continue
            skip_sign, reason = should_skip_signing(cwd=repo)
            if not do_commit(repo, rel, msg, skip_sign, reason):
                continue  # user declined unsigned commit


def cmd_push(root: str, extra_args: List[str]) -> None:
    """
    Push sequence (bottom-up):
      1. Push every submodule to its own remote.
      2. If submodule refs changed, stage + commit them in root.
      3. Push root.
    """
    repos      = build_repo_tree(root)
    submodules = repos[:-1]
    parent     = repos[-1]

    for repo in submodules:
        rel = os.path.relpath(repo, root)
        info("=== push submodule: {} ===".format(rel))
        run_git(["push"] + extra_args, cwd=repo)

    if submodules and submodule_refs_dirty(parent):
        info("Staging updated submodule refs in root repo...")
        run_git(["add"] + [os.path.relpath(s, parent) for s in submodules],
                cwd=parent)
        skip_sign, reason = should_skip_signing(cwd=parent)
        do_commit(parent, ".", CONFIG.ref_commit_msg, skip_sign, reason)

    info("=== push root: {} ===".format(os.path.basename(parent)))
    run_git(["push"] + extra_args, cwd=parent)


def cmd_pull(root: str, extra_args: List[str]) -> None:
    """Pull root, then sync and update all submodules recursively."""
    info("=== pull root: {} ===".format(os.path.basename(root)))
    run_git(["pull"] + extra_args, cwd=root)

    if get_submodule_paths(root):
        info("Updating submodules...")
        run_git(["submodule", "sync", "--recursive"], cwd=root)
        run_git(["submodule", "update", "--init", "--recursive"], cwd=root)


def cmd_upsub(root: str, extra_args: List[str]) -> None:
    """
    Advance each submodule to the latest commit on its tracked remote branch,
    then stage the updated ref pointers in the parent.

    This is a deliberate write operation — it changes which submodule commits
    the parent records. After running this, use 'mgit commit' and 'mgit push'
    to persist the updated pointers.

    Specific submodule paths can be given as extra args to limit the update:
      mgit upsub src/jcom
    Without args, all submodules are updated.
    """
    subs = get_submodule_paths(root)
    if not subs:
        info("No submodules found in {}.".format(os.path.basename(root)))
        return

    info("=== upsub: advancing submodule pointers to latest remote ===")

    # If specific paths given, validate and filter
    if extra_args:
        requested = [os.path.normpath(os.path.join(root, p)) for p in extra_args]
        unknown   = [p for p in requested if p not in subs]
        if unknown:
            die("Unknown submodule path(s): {}".format(
                ", ".join(os.path.relpath(p, root) for p in unknown)))
        update_args = extra_args  # pass as-is to git (relative paths)
    else:
        update_args = []

    run_git(["submodule", "update", "--remote", "--recursive"] + update_args, cwd=root)

    # Stage any pointers that actually changed
    if submodule_refs_dirty(root):
        if extra_args:
            run_git(["add"] + [os.path.join(root, p) for p in extra_args], cwd=root)
        else:
            for sub in subs:
                run_git(["add", sub], cwd=root)
        info("Submodule ref(s) staged. Run 'mgit commit' then 'mgit push' to persist.")
    else:
        info("Submodule(s) already at latest — nothing to stage.")

    # Reattach each submodule to its remote default branch.
    # git submodule update --remote always leaves a detached HEAD; undo that
    # so the working tree is navigable without any .gitmodules configuration.
    targets = [os.path.join(root, p) for p in extra_args] if extra_args else subs
    for sub in targets:
        rel = os.path.relpath(sub, root)
        branch = submodule_remote_branch(sub)
        if not branch:
            verbose("Cannot determine remote branch for {}, leaving detached.".format(rel))
            continue
        info("Reattaching {} → {}.".format(rel, branch))
        run_git(["checkout", branch], cwd=sub, check=False)
        run_git(["merge", "--ff-only", "origin/{}".format(branch)], cwd=sub, check=False)


