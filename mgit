# Remote / repo name helpers
# ---------------------------------------------------------------------------

def get_origin_url(cwd: str = None) -> str:
    """Return the origin remote URL, or '' if none."""
    return git_output(["remote", "get-url", "origin"], cwd=cwd)


def repo_name_from_url(url: str) -> str:
    """
    Extract the bare repo name from a remote URL.
    Handles both https://github.com/owner/name.git and git@github.com:owner/name.git.
    Returns '' if parsing fails.
    """
    if not url:
        return ""
    url = re.sub(r"\.git$", "", url)
    parts = [p for p in re.split(r"[/:]", url) if p]
    return parts[-1] if parts else ""


def gh_repo_owner() -> str:
    """Return the authenticated GitHub username via gh, or ''."""
    return gh_output(["api", "user", "--jq", ".login"])


def gh_user_orgs() -> List[str]:
    """
    Return a list of org login names that the authenticated user belongs to.
    Returns [] if the user has no org memberships or if the token does not
    have read:org scope (e.g. a fine-grained PAT).

    Uses plain 'gh org list' without --json since the --json flag was added
    in a later version of gh and is not universally available.
    The plain output is one org login per line (with an optional header line
    like "Showing 2 of 2 organizations" which is filtered out).
    """
    result = run_gh(
        ["org", "list", "--limit", "100"],
        check=False, capture=True
    )
    if result.returncode != 0:
        return []
    orgs = []
    for line in result.stdout.splitlines():
        line = line.strip()
        if not line:
            continue
        # Skip the summary header line gh prints before the list
        # !!! TODO : What if, in the future, 'gh' supports i18n/l10n? Will it still work? !!!
        if line.lower().startswith("showing ") and " organization" in line.lower():
            continue
        if line.lower() == "there are no organizations":
            return []
        orgs.append(line)
    return orgs


def gh_get_owner(cwd: str = None) -> str:
    """
    Determine the GitHub owner (user or org) for a new repository.

    - Fetches the authenticated user's login and their org memberships.
    - If the user has no org memberships, returns their personal login
      immediately without prompting.
    - Otherwise presents a numbered menu: personal account first, then
      each org, and returns the selected login.

    Personal is always the authenticated gh user — never inferred from
    the current repo's remote URL.
    """
    gh_user = gh_repo_owner()
    if not gh_user:
        die("Could not determine authenticated GitHub user. "
            "Check that gh is authenticated (gh auth status).")

    orgs = gh_user_orgs()

    if not orgs:
        return gh_user

    choices = [gh_user] + orgs
    print()
    info("Where should the new repo be created?")
    for i, name in enumerate(choices, 1):
        label = "(personal)" if i == 1 else "(org)"
        print("  {:2d}. {} {}".format(i, name, label), file=sys.stderr)
    print(file=sys.stderr)

    while True:
        raw = prompt("Select owner [1-{}]".format(len(choices)), default="1")
        try:
            idx = int(raw) - 1
            if 0 <= idx < len(choices):
                return choices[idx]
        except ValueError:
            pass
        warn("Please enter a number between 1 and {}.".format(len(choices)))

