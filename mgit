def cmd_log(root: str, extra_args: List[str]) -> None:
    for repo in build_repo_tree_topdown(root):
        rel = os.path.relpath(repo, root) if repo != root else "."
        info("=== log: {} ===".format(rel))
        run_git(["log"] + extra_args, cwd=repo, check=False)
        print()


def cmd_passthrough(command: str, root: str, extra_args: List[str]) -> None:
    """Pass any unrecognised git command through to all repos top-down."""
    for repo in build_repo_tree_topdown(root):
        rel = os.path.relpath(repo, root) if repo != root else "."
        info("=== {}: {} ===".format(command, rel))
        run_git([command] + extra_args, cwd=repo, check=False)
        print()

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

KNOWN_COMMANDS = {
    "status":  cmd_status,
    "add":     cmd_add,
    "commit":  cmd_commit,
    "push":    cmd_push,
    "pull":    cmd_pull,
    "fetch":   cmd_fetch,
    "diff":    cmd_diff,
    "log":     cmd_log,
    "detach":  cmd_detach,
    "attach":  cmd_attach,
}


def main() -> None:
    if len(sys.argv) < 2:
        print("mgit v{} - multi-repo git wrapper".format(VERSION))
        print("Usage: mgit <git-command> [args...]")
        print()
        print("Supported multi-repo commands:")
        print("  status, add, commit [-m \"msg\"], push, pull, fetch, diff, log")
        print()
        print("Submodule management (requires gh CLI):")
        print("  detach <subdir>                  — detach subdir; contents wrapped in <subdir>/ in new repo")
        print("  detach <subdir>/                 — detach flat (trailing slash = no wrapper subdir)")
        print("  detach <subdir>/*                — detach flat from shell-expanded contents")
        print("  detach <subdir> --dest-subdir <name>  — wrap contents in <name>/ explicitly")
        print("  detach <subdir> --no-dest-subdir      — flat copy explicitly")
        print("  attach <subdir> <submodule-path> — move subdir contents into an existing submodule")
        print()
        print("Any other git command is passed through to all repos.")
        print("Run from any directory inside a git repo.")
        print()
        print("gh authentication (detach/attach only):")
        print("  Requires a classic PAT with scopes: repo, read:org, gist")
        print("  Set via gh auth login, GH_TOKEN env var, or [gh] token in ~/.mgitconfig")
        print("  Fine-grained tokens cannot list org memberships or create org repos.")
        print("  See README.md § 'GitHub CLI authentication' for full details.")
        sys.exit(0)

    if sys.argv[1] in ("--version", "-V"):
        print("mgit {}".format(VERSION))
        sys.exit(0)

    args = sys.argv[1:]
    if "--verbose" in args:
        CONFIG.verbose = True
        args = [a for a in args if a != "--verbose"]

    command    = args[0]
    extra_args = args[1:]

    cwd  = os.path.abspath(os.getcwd())
    root = find_invocation_root(cwd)

    verbose("Invocation root: {}".format(root))
    verbose("Command: {}  Extra args: {}".format(command, extra_args))

    if command in KNOWN_COMMANDS:
        KNOWN_COMMANDS[command](root, extra_args)
    else:
        cmd_passthrough(command, root, extra_args)


if __name__ == "__main__":
    main()
