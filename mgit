    print("  'gh' (GitHub CLI) is required for this command but was not found in PATH.")
    print()
    if system == "darwin":
        print("  Install with Homebrew:")
        print("      brew install gh")
        print()
        print("  Or download from: https://github.com/cli/cli/releases/latest")
    elif system == "linux":
        print("  Install on Debian/Ubuntu:")
        print("      sudo apt update && sudo apt install gh")
        print()
        print("  Install on CentOS/RHEL/Fedora:")
        print("      sudo dnf install gh")
        print()
        print("  Or download from: https://github.com/cli/cli/releases/latest")
    elif system == "windows":
        print("  Option 1 — winget (built into Windows 10/11):")
        print("      winget install --id GitHub.cli")
        print()
        print("  Option 2 — Scoop:")
        print("      scoop install gh")
        print()
        print("  Option 3 — manual download:")
        print("      https://github.com/cli/cli/releases/latest")
        print("      Download the *_windows_amd64.msi installer and run it.")
        print()
        print("  After installing, open a new terminal so PATH is refreshed.")
