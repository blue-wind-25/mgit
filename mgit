# Entry point
# ---------------------------------------------------------------------------

KNOWN_COMMANDS = {
    "status":  cmd_status,
    "add":     cmd_add,
    "commit":  cmd_commit,
    "push":    cmd_push,
    "pull":    cmd_pull,
    "fetch":   cmd_fetch,
    "diff":    cmd_diff,
    "log":     cmd_log,
    "sync":    cmd_sync,
    "upsub":   cmd_upsub,
    "detach":  cmd_detach,
    "attach":  cmd_attach,
}


def main() -> None:
    if len(sys.argv) < 2:
        print("mgit v{} - multi-repo git wrapper".format(VERSION))
        print("Usage: mgit <git-command> [args...]")
        print()
        print("Supported multi-repo commands:")
        print("  status, add, commit [-m \"msg\"], push, pull, fetch, diff, log")
        print()
        print("Submodule pointer update:")
        print("  upsub [path ...]  — advance submodule(s) to latest remote commit and")
        print("                     stage the updated ref pointer(s) in the parent.")
        print("                     Follow with 'mgit commit' and 'mgit push'.")
        print("                     Limit to specific submodules by passing their paths.")
        print()
        print("Recovery / catch-up:")
        print("  sync [-m \"msg\"]  — stage tracked changes (git add -u), commit, and push")
        print("                     all repos in correct order. Safe: never touches")
        print("                     untracked files or build artefacts. Default commit")
        print("                     message: 'chore: sync'. Also useful after using plain")
        print("                     git directly to restore consistent pushed state.")
        print()
        print("Submodule management (requires gh CLI):")
        print("  detach <subdir>                       — detach flat (contents at new repo root, default)")
        print("  detach <subdir>/*                     — detach flat from shell-expanded contents")
        print("  detach <subdir> --dest-subdir <name>  — wrap contents in <name>/ inside new repo")
        print("  detach <subdir> --no-dest-subdir      — flat copy (same as default, explicit)")
        print("  attach <subdir> <submodule-path> — move subdir contents into an existing submodule")
        print()
        print("Any other git command is passed through to all repos.")
        print("Run from any directory inside a git repo.")
        print()
        print("gh authentication (detach/attach only):")
        print("  Requires a classic PAT with scopes: repo, read:org, gist")
        print("  Set via gh auth login, GH_TOKEN env var, or [gh] token in ~/.mgitconfig")
        print("  Fine-grained tokens cannot list org memberships or create org repos.")
        print("  See README.md § 'GitHub CLI authentication' for full details.")
        sys.exit(0)

    if sys.argv[1] in ("--version", "-V"):
        print("mgit {}".format(VERSION))
        sys.exit(0)

    args = sys.argv[1:]
    if "--verbose" in args:
        CONFIG.verbose = True
        args = [a for a in args if a != "--verbose"]

    command    = args[0]
    extra_args = args[1:]

    cwd  = os.path.abspath(os.getcwd())
    root = find_invocation_root(cwd)

    verbose("Invocation root: {}".format(root))
    verbose("Command: {}  Extra args: {}".format(command, extra_args))

    if command in KNOWN_COMMANDS:
        KNOWN_COMMANDS[command](root, extra_args)
    else:
        cmd_passthrough(command, root, extra_args)


if __name__ == "__main__":
    main()
